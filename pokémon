

import random
import os
os.system("cls")

hp_vc = 100
hp_pc = 100

ataque = 10
cura = 5

defendendo_vc = False
defendendo_pc = False

print("\n A batalha começou!\n")

while hp_vc > 0 and hp_pc > 0:

    print("O que você quer fazer?")
    print("1 - Atacar")
    print("2 - Defender")
    print("3 - Curar")
    print("4 - Fugir")

    escolha = input("Escolha: ")

    if escolha == "1":
        dano = ataque

        if defendendo_pc:
            dano = dano / 2
            print("O oponente se defendeu, o cara ta no teto man!")

        hp_pc -= dano
        print(f"Você causou {dano} de danoboa lek!")

        defendendo_vc = False

    elif escolha == "2":
        print("Você está se defendendo, ou melhor dizendo se fudendo!")
        defendendo_vc = True

    elif escolha == "3":
        hp_vc += cura
        print(f"Você recuperou {cura} de vida,  boa escola lek!")

        defendendo_vc = False

    elif escolha == "4":
        print("\n Você fugiu da batalha... vc é a escoria da comunidade de pokémon LIXO!!!")
        print(" Fim de jogo!")
        break

    else:
        print("Você não fez nada... espere a lapada vir")
        defendendo_vc = False

    print(f"Vida do oponente: {hp_pc}")

    if hp_pc <= 0:
        print("\n Você venceu, tu é o melhor que dorme na sua cama!")
        break

    print("\nTurno do oponente...")

    escolha_pc = random.randint(1, 3)

    if escolha_pc == 1:
        dano = ataque

        if defendendo_vc:
            dano = dano / 2
            print("Você se defendeu, tororó!")

        hp_vc -= dano
        print(f"Oponente causou {dano} de dano, ele o que ele quer esta mole!")

        defendendo_pc = False

    elif escolha_pc == 2:
        print("Oponente está se defendendo!")
        defendendo_pc = True

    else:
        hp_pc += cura
        print("Oponente se curou!")

        defendendo_pc = False

    print(f"Sua vida: {hp_vc}\n")

    if hp_vc <= 0:
        print("\n Você perdeu!")

    defendendo_vc = False
    defendendo_pc = False

print("\ngame over!")